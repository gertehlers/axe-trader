{
  "name": "axe-trader-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "npm run test:api && npm run test:ui",
    "test:api": "vitest run --exclude '**/frontend/**'",
    "test:ui": "vitest run --root frontend",
    "typecheck": "tsc --noEmit && tsc --noEmit -p frontend",
    "build": "cd frontend && vite build",
    "dev:ui": "cd frontend && vite",
    "deploy": "npm run build && wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply axe-trader-dashboard --local",
    "migrate:remote": "wrangler d1 migrations apply axe-trader-dashboard --remote",
    "push": "tsx scripts/push-run.ts run.json",
    "pull": "tsx scripts/pull-feedback.ts"
  },
  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^8.1.2",
    "vitest": "^4.1",
    "wrangler": "^4"
  }
}
